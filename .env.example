# QQ Bot 凭据 (从 q.qq.com → 开发设置 获取)
QQ_APP_ID=你的QQ_APP_ID
QQ_APP_SECRET=你的QQ_APP_SECRET

# DeepSeek API (Anthropic 兼容端点)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=你的DeepSeek_API_Key

# 可选：沙箱模式 (默认 true，审核通过后设为 false)
SANDBOX=true

# 可选：系统提示词
SYSTEM_PROMPT=你是一个运行在QQ上的AI助手，请用中文回复。回复简洁友好，适合手机阅读。

# 可选：模型名称 (默认 deepseek-v4-pro)
# MODEL=deepseek-v4-pro
